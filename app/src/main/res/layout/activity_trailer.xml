<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- TOP BAR — Back + "Trailer" -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#0D0D0D">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_back"
            android:background="@drawable/circle_button_dark_bg"
            android:padding="9dp"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Trailer"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:fontFamily="@font/poppins_semibold" />

    </RelativeLayout>

    <!-- ScrollView to handle all content properly -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Video Container for WebView (starts hidden) -->
            <FrameLayout
                android:id="@+id/videoContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:visibility="gone"
                android:background="@android:color/black" />

            <!-- Thumbnail Container (visible initially) -->
            <FrameLayout
                android:id="@+id/thumbnailContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <ImageView
                    android:id="@+id/ivThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:alpha="0.5"
                    android:contentDescription="Trailer thumbnail" />

                <!-- Loading spinner -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#E53935"
                    android:visibility="gone" />

                <!-- Play button in the center -->
                <LinearLayout
                    android:id="@+id/btnPlayYouTube"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Red play circle -->
<!--                    <FrameLayout-->
<!--                        android:layout_width="64dp"-->
<!--                        android:layout_height="64dp"-->
<!--                        android:background="@drawable/circle_red_bg">-->

<!--                        <ImageView-->
<!--                            android:layout_width="28dp"-->
<!--                            android:layout_height="28dp"-->
<!--                            android:layout_gravity="center"-->
<!--                            android:src="@drawable/ic_play"-->
<!--                            android:contentDescription="Play"-->
<!--                            app:tint="#FFFFFF" />-->

<!--                    </FrameLayout>-->

<!--                    <TextView-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_marginTop="40dp"-->
<!--                        android:text="Loading Trailer ..."-->
<!--                        android:textColor="#FFFFFF"-->
<!--                        android:textSize="13sp"-->
<!--                        android:fontFamily="@font/poppins_semibold" />-->

                </LinearLayout>

            </FrameLayout>

            <!-- BOTTOM PANEL — Movie info (no fixed margin) -->
            <LinearLayout
                android:id="@+id/bottomPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D0D0D"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/tvMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEW · PG-13 · 1h 56m"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:letterSpacing="0.02" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/badgeNew"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="New"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:fontFamily="@font/poppins_bold"
                        android:background="@drawable/badge_red_bg"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />

                    <TextView
                        android:id="@+id/tvSeeMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="See more ›"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular" />

                    <TextView
                        android:id="@+id/tvMovieTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/badgeNew"
                        android:layout_toStartOf="@id/tvSeeMore"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp"
                        android:text="Movie Title"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="@font/poppins_bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                </RelativeLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/badgeAge"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="+17"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/badge_green_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />

                    <TextView
                        android:id="@+id/badgeLang"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:layout_marginStart="6dp"
                        android:text="EN"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/chip_inactive_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>