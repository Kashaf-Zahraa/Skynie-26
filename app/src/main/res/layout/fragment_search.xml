<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F0F">

    <!-- ── TOP BAR ────────────────────────────────────────────── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Search"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold" />

        <!-- Filter icon -->
        <ImageView
            android:id="@+id/btnFilter"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_filter"
            android:background="@drawable/circle_button_dark_bg"
            android:padding="8dp"
            android:contentDescription="Filter" />

    </RelativeLayout>

    <!-- ── SEARCH BAR ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/search_bar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search icon"
            android:alpha="0.5" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@null"
            android:hint="Search cinemas..."
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />
    </LinearLayout>

    <!-- ── FILTER CHIPS ───────────────────────────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/llFilterChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chipNearby"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/badge_red_bg"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Nearby"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold" />

            <TextView
                android:id="@+id/chipImax"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chip_inactive_bg"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="IMAX"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <TextView
                android:id="@+id/chipGold"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chip_inactive_bg"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="GOLD"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <TextView
                android:id="@+id/chipScreenX"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chip_inactive_bg"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="ScreenX"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <TextView
                android:id="@+id/chip4DMax"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/chip_inactive_bg"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="4D MAX"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

        </LinearLayout>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="250dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/skynie_red"/>

    <!-- ── CINEMAS LIST ───────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCinemas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

</LinearLayout>